generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  username     String         @unique
  passwordHash String
  isAdmin      Boolean        @default(false)
  createdAt    DateTime       @default(now())
  sessions     Session[]
  picks        Pick[]
  weeklyResults WeeklyResult[]
  leagueMembers LeagueMember[]
  createdLeagues League[]     @relation("CreatedBy")
  draftPicks     DraftPick[]
  autoQueues     AutoDraftQueue[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Season {
  id          String       @id @default(cuid())
  name        String
  year        Int
  isActive    Boolean      @default(false)
  tournaments Tournament[]
  leagues     League[]
}

model Tournament {
  id           String            @id @default(cuid())
  seasonId     String
  name         String
  course       String
  location     String
  startDate    DateTime
  endDate      DateTime
  pickDeadline DateTime
  isComplete   Boolean           @default(false)
  externalId   String?
  season       Season            @relation(fields: [seasonId], references: [id])
  field        TournamentField[]
  results      TournamentResult[]
  picks        Pick[]
  weeklyResults WeeklyResult[]
  drafts       Draft[]
}

model Golfer {
  id         String            @id @default(cuid())
  name       String
  ranking    Int?
  imageUrl   String?
  externalId String?
  fields     TournamentField[]
  results    TournamentResult[]
  picks      Pick[]
  draftPicks DraftPick[]
}

model TournamentField {
  id           String     @id @default(cuid())
  tournamentId String
  golferId     String
  odds         Int?       // betting odds (American format, e.g. 1100 = +1100)
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  golfer       Golfer     @relation(fields: [golferId], references: [id])

  @@unique([tournamentId, golferId])
}

model TournamentResult {
  id           String     @id @default(cuid())
  tournamentId String
  golferId     String
  position     Int?
  scoreToPar   Int?
  r1Score      Int?
  r2Score      Int?
  r3Score      Int?
  r4Score      Int?
  thru         Int?       // holes completed in current round (0-18); null = pre-tournament
  status       String     @default("active") // active, cut, wd, dq
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  golfer       Golfer     @relation(fields: [golferId], references: [id])

  @@unique([tournamentId, golferId])
}

model League {
  id        String         @id @default(cuid())
  name      String
  inviteCode String        @unique
  seasonId  String
  createdBy String
  season    Season         @relation(fields: [seasonId], references: [id])
  creator   User           @relation("CreatedBy", fields: [createdBy], references: [id])
  members   LeagueMember[]
  picks     Pick[]
  weeklyResults WeeklyResult[]
  drafts    Draft[]
}

model LeagueMember {
  id       String   @id @default(cuid())
  leagueId String
  userId   String
  joinedAt DateTime @default(now())
  league   League   @relation(fields: [leagueId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
}

model Pick {
  id           String     @id @default(cuid())
  leagueId     String
  userId       String
  tournamentId String
  golferId     String
  pickOrder    Int
  createdAt    DateTime   @default(now())
  league       League     @relation(fields: [leagueId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  golfer       Golfer     @relation(fields: [golferId], references: [id])

  @@unique([leagueId, userId, tournamentId, golferId])
}

model WeeklyResult {
  id           String     @id @default(cuid())
  leagueId     String
  userId       String
  tournamentId String
  totalScore   Int
  rank         Int
  points       Int
  league       League     @relation(fields: [leagueId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([leagueId, userId, tournamentId])
}

model Draft {
  id               String      @id @default(cuid())
  leagueId         String
  tournamentId     String
  status           String      @default("pending") // pending, active, complete
  currentRound     Int         @default(1)
  currentPickIndex Int         @default(0)
  draftOrder       String      // JSON array of userIds for round 1 order
  createdAt        DateTime    @default(now())
  league           League      @relation(fields: [leagueId], references: [id])
  tournament       Tournament  @relation(fields: [tournamentId], references: [id])
  picks            DraftPick[]
  autoQueues       AutoDraftQueue[]

  @@unique([leagueId, tournamentId])
}

model DraftPick {
  id         String   @id @default(cuid())
  draftId    String
  userId     String
  golferId   String
  round      Int
  pickNumber Int
  createdAt  DateTime @default(now())
  draft      Draft    @relation(fields: [draftId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  golfer     Golfer   @relation(fields: [golferId], references: [id])
}

model AutoDraftQueue {
  id         String   @id @default(cuid())
  draftId    String
  userId     String
  enabled    Boolean  @default(true)  // true when queue is set; user can toggle off
  queueOrder String   @default("[]")  // JSON array of golferIds in priority order
  updatedAt  DateTime @updatedAt
  draft      Draft    @relation(fields: [draftId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([draftId, userId])
}
